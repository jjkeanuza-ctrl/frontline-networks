/*
  # Prevent clickjacking — stops your site being embedded in iframes on other sites
  X-Frame-Options: DENY

  # Prevent MIME type sniffing — browser must respect declared content type
  X-Content-Type-Options: nosniff

  # XSS protection for older browsers
  X-XSS-Protection: 1; mode=block

  # Control referrer info sent to other sites
  Referrer-Policy: strict-origin-when-cross-origin

  # Restrict browser features — no camera, mic, location access
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()

  # Force HTTPS for 1 year — never allow plain HTTP
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy
  # Allows: your own files, Google Fonts, your Cloudflare Worker, Discord CDN for images
  # Blocks: everything else including inline scripts from other origins
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn.discordapp.com https://frontline-status.jjkeanuza.workers.dev; connect-src 'self' https://frontline-status.jjkeanuza.workers.dev https://fonts.googleapis.com; frame-ancestors 'none';

  # Cache control for HTML — always revalidate so updates show immediately
  Cache-Control: no-cache, must-revalidate

/assets/css/*
  # CSS files — cache for 1 year, use content hash for cache busting
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  # JS files — cache for 1 year
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  # Images — cache for 1 year
  Cache-Control: public, max-age=31536000, immutable
